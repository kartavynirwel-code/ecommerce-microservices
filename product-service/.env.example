# Copy this file to .env and fill in real values locally.
# NEVER commit the actual .env file.

SERVER_PORT=8082

DB_HOST=localhost
DB_PORT=3306
DB_NAME=product_db
DB_USER=changeme
DB_PASSWORD=changeme

# Must match the JWT_SECRET / JWT_ISSUER used by auth-service exactly.
JWT_SECRET=replace_with_a_long_random_secret_value
JWT_ISSUER=ecommerce-auth-service

CORS_ALLOWED_ORIGINS=http://localhost:3000
