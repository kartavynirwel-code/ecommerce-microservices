# =============================================================================
# Root env file for docker-compose (compose auto-loads a file named ".env"
# from the same folder as docker-compose.yml).
#
# Copy this to ".env" (already gitignored) and fill in REAL values before
# running docker-compose. Never commit the real ".env" file.
#
# Hostnames below use docker-compose SERVICE NAMES (not localhost), since
# containers talk to each other over the compose network. Adjust the
# service names here to match whatever you name them in docker-compose.yml.
# =============================================================================

# ---------- MySQL (shared container, one instance, 4 databases) ----------
MYSQL_ROOT_PASSWORD=CHANGE_ME_root_password
MYSQL_HOST=mysql
MYSQL_PORT=3306

# App-level DB user (created via db/init.sql) - used by all 4 services
DB_USER=ecommerce_app
DB_PASSWORD=CHANGE_ME_strong_password

# ---------- JWT (MUST be identical across auth/product/order/cart) ----------
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_long_random_jwt_secret
JWT_EXPIRATION_MS=3600000
JWT_ISSUER=ecommerce-auth-service
JWT_ALGORITHM=HS256

# ---------- auth-service ----------
AUTH_SERVER_PORT=8081
AUTH_DB_HOST=${MYSQL_HOST}
AUTH_DB_PORT=${MYSQL_PORT}
AUTH_DB_NAME=auth_db
AUTH_DB_USER=${DB_USER}
AUTH_DB_PASSWORD=${DB_PASSWORD}

# ---------- product-service ----------
PRODUCT_SERVER_PORT=8082
PRODUCT_DB_HOST=${MYSQL_HOST}
PRODUCT_DB_PORT=${MYSQL_PORT}
PRODUCT_DB_NAME=product_db
PRODUCT_DB_USER=${DB_USER}
PRODUCT_DB_PASSWORD=${DB_PASSWORD}

# ---------- order-service ----------
ORDER_SERVER_PORT=5001
ORDER_DB_HOST=${MYSQL_HOST}
ORDER_DB_PORT=${MYSQL_PORT}
ORDER_DB_NAME=order_db
ORDER_DB_USER=${DB_USER}
ORDER_DB_PASSWORD=${DB_PASSWORD}

# ---------- cart-service ----------
CART_SERVER_PORT=8000
CART_DB_HOST=${MYSQL_HOST}
CART_DB_PORT=${MYSQL_PORT}
CART_DB_NAME=cart_db
CART_DB_USER=${DB_USER}
CART_DB_PASSWORD=${DB_PASSWORD}
PRODUCT_SERVICE_URL=http://product-service:8082

# ---------- CORS (allow the frontend origin) ----------
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ---------- frontend (Vite - these are NOT secrets, just service URLs) ----------
# Inside docker-compose network, use service names; browser still needs to
# reach exposed host ports, so usually keep these as localhost + published port.
VITE_AUTH_SERVICE_URL=http://localhost:8081
VITE_PRODUCT_SERVICE_URL=http://localhost:8082
VITE_ORDER_SERVICE_URL=http://localhost:5001
VITE_CART_SERVICE_URL=http://localhost:8000
