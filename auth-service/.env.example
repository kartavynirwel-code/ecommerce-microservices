# Copy this file to .env and fill in real values locally.
# NEVER commit the actual .env file - it is already excluded via .gitignore.
# In real deployments (DevSecOps pipeline) these should come from a secrets
# manager / vault / CI-CD secret store, not from a checked-in file.

SERVER_PORT=8081

DB_HOST=localhost
DB_PORT=3306
DB_NAME=auth_db
DB_USER=changeme
DB_PASSWORD=changeme

# Shared secret used to sign JWTs. Must be identical across all services that
# validate tokens (auth-service, product-service, order-service, cart-service).
# Generate a strong random value, e.g.: openssl rand -base64 64
JWT_SECRET=replace_with_a_long_random_secret_value
JWT_EXPIRATION_MS=3600000
JWT_ISSUER=ecommerce-auth-service

CORS_ALLOWED_ORIGINS=http://localhost:3000
