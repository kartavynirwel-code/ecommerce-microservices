# Copy this file to .env and fill in real values locally.
# NEVER commit the actual .env file.

SERVER_PORT=8000

DB_HOST=localhost
DB_PORT=3306
DB_NAME=cart_db
DB_USER=changeme
DB_PASSWORD=changeme

# Must match the JWT_SECRET used by auth-service exactly.
JWT_SECRET=replace_with_a_long_random_secret_value
JWT_ALGORITHM=HS256

CORS_ALLOWED_ORIGINS=http://localhost:3000

PRODUCT_SERVICE_URL=http://localhost:8082
